#!/bin/sh
# Launcher for the standalone Zonos GPU TTS engine (Linux x64, NVIDIA).
#
# The release workflow builds a self-contained PyInstaller bundle next to this script: an embedded
# Python interpreter plus the PyTorch CUDA wheels (which carry their own CUDA runtime), the Zonos
# package, and the model weights + reference-voice bank. So an end user needs ONLY a compatible
# NVIDIA GPU and its normal driver: no system Python, no CUDA toolkit, no dev environment.
#
# The PyInstaller executable lives under runtime/zonos-engine next to this script and speaks the
# same --stdio protocol the plugin drives. If a frozen exe is not present (e.g. running from a
# source checkout), fall back to `python3 -m zonos_engine`.
#
# Linux is a follow-up target; Windows x64 is the primary gaming-PC target for v1.
#
# Usage: zonos-engine --stdio | --selftest [--wav out.wav] | --mock ...
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -x "$DIR/runtime/zonos-engine" ]; then
  exec "$DIR/runtime/zonos-engine" "$@"
else
  exec python3 -m zonos_engine "$@"
fi
